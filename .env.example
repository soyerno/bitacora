# Erno × MODO — environment template. Copiar a .env.local y completar.
# En Vercel: setearlas en Project → Settings → Environment Variables (NO commitear .env).

# Dominio público de ESTA bitácora. Default fallback (config) apunta a GH Pages
# vieja; al pasar a Vercel/dominio custom, override acá.
NEXT_PUBLIC_BASE_URL=

# Token para acceder a items visibility=org vía /api/feed/<section>.
# Sin esta var seteada, /api/feed/* solo devuelve items public.
# Rotate: cuando se compromete, generar uno nuevo + actualizar consumers.
# Govern (adapter ingest-bitacora) lo lee de su vault (SPEC-099) por dev.
ORG_FEED_TOKEN=
