---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} · erno-modo</title>
		<style>
			:root {
				color-scheme: light dark;
				--fg: #1a1a1a;
				--bg: #ffffff;
				--muted: #666;
				--accent: #7c5cff;
				--border: #e5e5e5;
			}
			@media (prefers-color-scheme: dark) {
				:root {
					--fg: #e8e8e8;
					--bg: #121212;
					--muted: #999;
					--border: #2a2a2a;
				}
			}
			* { box-sizing: border-box; }
			body {
				margin: 0;
				font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
				background: var(--bg);
				color: var(--fg);
				line-height: 1.6;
			}
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2.5rem 1.25rem 4rem;
			}
			nav {
				display: flex;
				gap: 1.25rem;
				padding: 1.25rem;
				border-bottom: 1px solid var(--border);
				max-width: 720px;
				margin: 0 auto;
			}
			nav a {
				color: var(--fg);
				text-decoration: none;
				font-weight: 600;
			}
			nav a:hover { color: var(--accent); }
			a { color: var(--accent); }
			h1 { font-size: 1.75rem; }
			.muted { color: var(--muted); font-size: 0.9rem; }
			.tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 0.5rem 0 1.5rem; }
			.tag {
				font-size: 0.75rem;
				color: var(--muted);
				border: 1px solid var(--border);
				border-radius: 999px;
				padding: 0.15rem 0.6rem;
			}
			.entry-list { list-style: none; padding: 0; }
			.entry-list li {
				padding: 1rem 0;
				border-bottom: 1px solid var(--border);
			}
			.entry-list a { text-decoration: none; font-weight: 600; }
			pre {
				overflow-x: auto;
				background: color-mix(in srgb, var(--fg) 5%, transparent);
				padding: 0.75rem;
				border-radius: 6px;
			}
			code { font-family: ui-monospace, "SF Mono", Consolas, monospace; }
		</style>
	</head>
	<body>
		<nav>
			<a href="/">erno-modo</a>
			<a href="/">bitácora</a>
			<a href="/boveda/">bóveda</a>
		</nav>
		<main>
			<slot />
		</main>
	</body>
</html>
