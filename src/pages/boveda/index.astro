---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const notes = await getCollection('boveda');
---

<Base title="Bóveda">
	<h1>Bóveda</h1>
	<p class="muted">Notas de referencia, limpias y sin fecha.</p>
	{notes.length === 0 ? (
		<p class="muted">Todavía no hay notas aquí.</p>
	) : (
		<ul class="entry-list">
			{notes.map((note) => (
				<li>
					<a href={`/boveda/${note.id}/`}>{note.data.title}</a>
				</li>
			))}
		</ul>
	)}
</Base>
